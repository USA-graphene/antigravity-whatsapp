# ──────────────────────────────────────────────
# Antigravity-WhatsApp Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Required: Google Gemini API key
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Model to use (default: gemma-4-31b-it)
# Options: gemma-4-31b-it, gemma-4-26b-it, gemini-2.0-flash, etc.
ANTIGRAVITY_MODEL=gemma-4-31b-it

# Workspace directory for file operations (default: current dir)
ANTIGRAVITY_WORKSPACE=.

# Comma-separated phone numbers allowed to use the bot (E.164 format)
# Leave empty to allow all paired contacts (NOT recommended for production)
ANTIGRAVITY_ALLOWED=+15555550123,+15555550456

# Command execution timeout in seconds (default: 30)
ANTIGRAVITY_CMD_TIMEOUT=30

# Max response length per WhatsApp message chunk (default: 4000)
ANTIGRAVITY_MAX_CHUNK=4000

# Session history: max messages to keep per conversation (default: 50)
ANTIGRAVITY_MAX_HISTORY=50

# Log level: debug, info, warn, error (default: info)
ANTIGRAVITY_LOG_LEVEL=info
